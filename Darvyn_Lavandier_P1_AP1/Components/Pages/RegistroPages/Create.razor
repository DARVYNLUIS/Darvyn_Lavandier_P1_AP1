@page "/Registro/Create"
@using DarvynLuisLavandier_P1_AP1.Service
@using DarvynLuisLavandier_P1_AP1.Models
@inject RegistroService RegistroService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<EditForm Model="Registro" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />
    <div class="card shadow-lg border-0 rounded">
        <div class="card-header bg-primary text-white text-center">
            <h3><i class="fas fa-clipboard-list"></i> Registro de Nombres</h3>
        </div>

        <div class="card-body">
            <div class="mb-3">
                <label for="Nombres" class="form-label">Nombres:</label>
                <InputText id="Nombres" @bind-Value="Registro.Nombres" class="form-control" />
                <ValidationMessage For="@(() => Registro.Nombres)" />
            </div>
        </div> 

        <div class="card-footer bg-light d-flex justify-content-center mt-3">
            <div class="btn-group">
                <button type="button" class="btn btn-outline-primary ml-2" @onclick="Nuevo">
                    <span class="bi bi-plus"></span> Nuevo
                </button>
                <button type="submit" class="btn btn-outline-success ml-2">
                    <span class="bi bi-check-circle-fill"></span> Guardar
                </button>
                <a href="/Registro/Index" class="btn btn-outline-danger ml-2">
                    <span class="bi bi-arrow-bar-left"></span> Retroceder
                </a>
            </div>
        </div>
    </div>
</EditForm>


@code {
    public Registros Registro { get; set; } = new Registros();

    public void Nuevo()
    {
        Registro = new Registros();
    }

    public async Task Guardar()
    {
        try
        {
            if (Registro == null)
            {
                throw new InvalidOperationException("El objeto Registro no está inicializado.");
            }

            bool guardo = await RegistroService.Guardar(Registro);
            if (guardo)
            {
                Nuevo();
                NavigationManager.NavigateTo("/Registro/Index");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar el registro: {ex.Message}");
        }
    }
}
